# VaultX Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# Flask secret key - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_64_char_hex_string

# development | production
FLASK_ENV=development

# Database - leave unset locally to use SQLite fallback (backend/vaultx.db)
# Railway auto-sets this when you attach a PostgreSQL plugin
DATABASE_URL=

# HashiCorp Vault
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=root
VAULT_SECRET_PATH=vaultx-key
USE_VAULT=true

# CORS - comma-separated list of allowed origins, or * for all
ALLOWED_ORIGINS=*
